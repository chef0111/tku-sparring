# DATABASE_URL
DATABASE_URL=""       # Get connection string from https://cloud.mongodb.com/

# BETTER-AUTH
# Dev: https://tku-sparring.localhost  |  Prod: https://tku-sparring.vercel.app
BETTER_AUTH_URL=https://tku-sparring.localhost
BETTER_AUTH_SECRET=   # Generate secret via https://better-auth.com/docs/installation

# --- Tournament realtime (main app → external Socket.io service) ---
# Secrets must match the realtime service (INTERNAL_BROADCAST_SECRET + TOURNAMENT_SOCKET_JWT_SECRET there).
#
# Local dev (app at https://tku-sparring.localhost, realtime on this machine):
REALTIME_INTERNAL_BROADCAST_URL=http://localhost:3331/internal/broadcast
REALTIME_INTERNAL_BROADCAST_SECRET=dev-shared-secret
TOURNAMENT_SOCKET_JWT_SECRET=dev-jwt-secret-at-least-32-chars-recommended
VITE_REALTIME_URL=http://localhost:3331
#
# Production (Vercel app + hosted realtime, e.g. https://tku-realtime.fly.dev):
# REALTIME_INTERNAL_BROADCAST_URL=https://tku-realtime.fly.dev/internal/broadcast
# REALTIME_INTERNAL_BROADCAST_SECRET=<same-as-realtime-INTERNAL_BROADCAST_SECRET>
# TOURNAMENT_SOCKET_JWT_SECRET=<same-as-realtime-TOURNAMENT_SOCKET_JWT_SECRET>
# VITE_REALTIME_URL=https://tku-realtime.fly.dev
