{
  "name": "tku-sparring",
  "version": "2.3.1",
  "private": true,
  "type": "module",
  "description": "A modern, user-friendly web application for managing Taekwondo sparring matches.",
  "homepage": "https://tku-sparring.vercel.app",
  "license": "MIT",
  "author": {
    "name": "Le Tran Gia Bao",
    "email": "letrangiabao14@gmail.com",
    "url": "https://github.com/chef0111"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chef0111/tku-sparring.git"
  },
  "scripts": {
    "dev": "portless tss vite dev --port 3000",
    "build": "bun run db:generate && vite build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "preview": "portless tss vite preview",
    "start": "vite build && portless tss vite preview",
    "test": "vitest run",
    "typecheck": "tsgo --skipLibCheck --extendedDiagnostics",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "upgrade:auth": "npx auth upgrade",
    "upgrade:tailwind": "npx @tailwindcss/upgrade@latest",
    "skills:add": "npx skills@latest add",
    "intent": "npx @tanstack/intent install",
    "intent:ls": "npx @tanstack/intent@latest list",
    "intent:load": "npx @tanstack/intent@latest load",
    "prepare": "husky"
  },
