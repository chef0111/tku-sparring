generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @map("_id") @db.String
  name            String
  email           String
  emailVerified   Boolean   @default(false)
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  username        String?
  displayUsername String?
  sessions        Session[]
  accounts        Account[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @map("_id") @db.String
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @map("_id") @db.String
  accountId             String
  providerId            String
  userId                String    @db.String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @map("_id") @db.String
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Tournament {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  nameSortKey  String   @default("")
  status       String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups             Group[]
  matches            Match[]
  groupControlLeases GroupControlLease[]
  activities         TournamentActivity[]
  tournamentAthletes TournamentAthlete[]

  @@map("tournament")
}

model Group {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  tournamentId    String   @db.ObjectId
  gender          String?
  beltMin         Int?
  beltMax         Int?
  weightMin       Float?
  weightMax       Float?
  thirdPlaceMatch Boolean  @default(false)
  arenaIndex      Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tournament         Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  controlLease       GroupControlLease?
  matches            Match[]
  tournamentAthletes TournamentAthlete[]

  @@index([tournamentId])
  @@map("group")
}

model Match {
  id                       String   @id @default(auto()) @map("_id") @db.ObjectId
  round                    Int      @default(0)
  matchIndex               Int      @default(0)
  status                   String   @default("pending")
  bestOf                   Int      @default(3)
  redAthleteId             String?  @db.ObjectId
  blueAthleteId            String?  @db.ObjectId
  redTournamentAthleteId   String?  @db.ObjectId
  blueTournamentAthleteId  String?  @db.ObjectId
  redWins                  Int      @default(0)
  blueWins                 Int      @default(0)
  winnerId                 String?  @db.ObjectId
  winnerTournamentAthleteId String? @db.ObjectId
  redLocked                Boolean  @default(false)
  blueLocked               Boolean  @default(false)
  groupId                  String   @db.ObjectId
  tournamentId             String   @db.ObjectId
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([tournamentId])
  @@map("match")
}

model AthleteProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  athleteCode String?
  name        String
  nameSortKey String   @default("")
  gender      String
  beltLevel   Int
  weight      Float
  affiliation String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tournamentAthletes TournamentAthlete[]

  @@index([athleteCode])
  @@index([name, affiliation, beltLevel, weight])
  @@map("athlete_profile")
}

model TournamentAthlete {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId     String  @db.ObjectId
  athleteProfileId String  @db.ObjectId
  groupId          String? @db.ObjectId
  seed             Int?
  locked           Boolean @default(false)
  status           String  @default("selected")
  notes            String?

  name         String
  nameSortKey  String   @default("")
  gender       String
  beltLevel   Int
  weight      Float
  affiliation String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament     Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  athleteProfile AthleteProfile @relation(fields: [athleteProfileId], references: [id], onDelete: Cascade)
  group          Group?         @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, athleteProfileId])
  @@index([tournamentId])
  @@index([groupId])
  @@map("tournament_athlete")
}

model TournamentActivity {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String   @db.ObjectId
  adminId      String   @db.String
  eventType    String
  entityType   String
  entityId     String
  payload      Json
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, createdAt])
  @@index([eventType])
  @@map("tournament_activity")
}

model GroupControlLease {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId         String   @db.ObjectId
  tournamentId    String   @db.ObjectId
  adminId         String   @db.String
  deviceId        String
  acquiredAt      DateTime
  lastHeartbeatAt DateTime
  expiresAt       DateTime

  group            Group                 @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tournament       Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  takeoverRequests LeaseTakeoverRequest[]

  @@unique([groupId])
  @@index([tournamentId])
  @@index([expiresAt])
  @@map("group_control_lease")
}

model LeaseTakeoverRequest {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  leaseId           String   @db.ObjectId
  requesterDeviceId String
  requesterAdminId  String   @db.String
  createdAt         DateTime @default(now())
  status            String   @default("pending")

  lease GroupControlLease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@unique([leaseId, requesterDeviceId, requesterAdminId])
  @@index([leaseId, status, createdAt])
  @@index([requesterDeviceId])
  @@map("lease_takeover_request")
}
