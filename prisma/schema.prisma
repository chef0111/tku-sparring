generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  name                 String
  email                String
  emailVerified        Boolean               @default(false)
  image                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  username             String?
  displayUsername      String?
  sessions             Session[]
  accounts             Account[]
  deviceLastSelections DeviceLastSelection[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Tournament {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  nameSortKey     String   @default("")
  status          String   @default("draft")
  arenaDivisionOrder Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  divisions          Division[]
  matches            Match[]
  activities         TournamentActivity[]
  tournamentAthletes TournamentAthlete[]

  @@map("tournament")
}

model Division {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  tournamentId    String   @db.Uuid
  gender          String?
  beltMin         Int?
  beltMax         Int?
  weightMin       Float?
  weightMax       Float?
  thirdPlaceMatch Boolean  @default(false)
  arenaIndex      Int      @default(1)
  round0Baseline  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tournament         Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches            Match[]
  tournamentAthletes TournamentAthlete[]

  @@index([tournamentId])
  @@map("division")
}

model ArenaMatchClaim {
  id           String   @id @default(uuid()) @db.Uuid
  matchId      String   @unique @db.Uuid
  divisionId   String   @db.Uuid
  tournamentId String   @db.Uuid
  deviceId     String
  userId       String   @db.Uuid
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([divisionId])
  @@index([expiresAt])
  @@map("arena_match_claim")
}

model Match {
  id                      String   @id @default(uuid()) @db.Uuid
  kind                    String   @default("bracket")
  displayLabel            String?
  round                   Int      @default(0)
  matchIndex              Int      @default(0)
  status                  String   @default("pending")
  redAthleteId            String?  @db.Uuid
  blueAthleteId           String?  @db.Uuid
  redTournamentAthleteId  String?  @db.Uuid
  blueTournamentAthleteId String?  @db.Uuid
  redWins                 Int      @default(0)
  blueWins                Int      @default(0)
  winnerId                String?  @db.Uuid
  tournamentWinnerId      String?  @db.Uuid
  redLocked               Boolean  @default(false)
  blueLocked              Boolean  @default(false)
  cornersSwapped          Boolean  @default(false)
  divisionId              String   @db.Uuid
  tournamentId            String   @db.Uuid
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  division        Division         @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  tournament      Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  arenaMatchClaim ArenaMatchClaim?

  @@index([divisionId])
  @@index([tournamentId])
  @@index([tournamentId, displayLabel])
  @@map("match")
}

model AthleteProfile {
  id          String   @id @default(uuid()) @db.Uuid
  athleteCode String?
  name        String
  nameSortKey String   @default("")
  gender      String
  beltLevel   Int
  weight      Float
  affiliation String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tournamentAthletes TournamentAthlete[]

  @@index([athleteCode])
  @@index([name, affiliation, beltLevel, weight])
  @@map("athlete_profile")
}

model TournamentAthlete {
  id               String  @id @default(uuid()) @db.Uuid
  tournamentId     String  @db.Uuid
  athleteProfileId String  @db.Uuid
  divisionId       String? @db.Uuid
  seed             Int?
  locked           Boolean @default(false)
  status           String  @default("selected")
  notes            String?

  name        String
  nameSortKey String  @default("")
  gender      String
  beltLevel   Int
  weight      Float
  affiliation String
  image       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament     Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  athleteProfile AthleteProfile @relation(fields: [athleteProfileId], references: [id], onDelete: Cascade)
  division       Division?      @relation(fields: [divisionId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, athleteProfileId])
  @@index([tournamentId])
  @@index([divisionId])
  @@map("tournament_athlete")
}

model TournamentActivity {
  id           String   @id @default(uuid()) @db.Uuid
  tournamentId String   @db.Uuid
  adminId      String   @db.Uuid
  eventType    String
  entityType   String
  entityId     String
  payload      Json
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, createdAt])
  @@index([eventType])
  @@map("tournament_activity")
}

model DeviceLastSelection {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  deviceId     String
  tournamentId String?  @db.Uuid
  divisionId   String?  @db.Uuid
  matchId      String?  @db.Uuid
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([deviceId])
  @@map("device_last_selection")
}
